# PDF MCP Server Configuration

# Logging
LOG_LEVEL=INFO

# Optional: Default output directory for temporary OCR files
# PDF_TEMP_DIR=/tmp/pdf_mcp

# Optional: OCRmyPDF settings
# OCRMYPDF_LANGUAGE=eng  # Language for OCR (eng, deu, fra, etc.)
# OCRMYPDF_SKIP_TEXT=false  # Set to true to skip OCR if PDF already has text
